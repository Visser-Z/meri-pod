# Meri POD — environment variables
# Copy to .env.local and fill in values

# Postgres — Supabase connection pooler URL
DATABASE_URL=postgresql://postgres.xxxx:[password]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Supabase — get from Supabase dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# MVP default company
DEFAULT_COMPANY_ID=1ceb5bb4-d558-4231-8544-eb9073804238
